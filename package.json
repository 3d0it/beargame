{
  "name": "beargame",
  "version": "1.0.0",
  "private": true,
  "license": "MIT",
  "engines": {
    "node": ">=22.0.0"
  },
  "description": "Simulatore web + android del Gioco dell'Orso",
  "scripts": {
    "build": "echo 'Build static web: no-op'",
    "serve": "node ./scripts/serve-web.mjs",
    "assets:playstore": "node ./scripts/generate-playstore-assets.mjs",
    "assets:android": "npx @capacitor/assets generate --android --assetPath assets",
    "cap:sync": "npx cap sync android",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "test:e2e:smoke": "PW_VIEWPORT_PROFILE=smoke playwright test",
    "test:e2e:full": "PW_VIEWPORT_PROFILE=full playwright test",
    "test:ui": "vitest run web/ui.integration.test.js",
    "test:coverage": "vitest run --coverage"
  },
  "devDependencies": {
    "@capacitor/android": "^8.1.0",
    "@capacitor/cli": "^8.1.0",
    "@capacitor/core": "^8.1.0",
    "@playwright/test": "^1.58.2",
    "@vitest/coverage-v8": "^4.0.18",
    "jsdom": "^26.1.0",
    "vitest": "^4.0.18"
  }
}
